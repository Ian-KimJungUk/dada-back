# Prisma / PostgreSQL 연결 문자열
# 형식: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://ian:ian@localhost:5442/dada?schema=public"

# Redis 연결 문자열
# 형식: redis://[:PASSWORD@]HOST:PORT[/DB]
REDIS_URL="redis://localhost:6379"

# JWT 서명 시크릿 (프로덕션은 반드시 강력한 랜덤 값으로 교체)
JWT_SECRET="dev-only-change-me"
